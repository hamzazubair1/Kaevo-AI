# ============================================================================
# Kaevo AI — .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
.venv/
env/
.env.local
.env.development.local
.env.test.local
.env.production.local

# ----------------------------------------------------------------------------
# Environment & Secrets
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ----------------------------------------------------------------------------
# Build Output
# ----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
*.tsbuildinfo

# ----------------------------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ----------------------------------------------------------------------------
# OS Files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Testing
# ----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.pytest_cache/
htmlcov/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
*.tgz
.cache/
.parcel-cache/
.temp/
.tmp/

# ----------------------------------------------------------------------------
# Client Data (Sensitive)
# ----------------------------------------------------------------------------
clients/*/data/
clients/*/credentials/
